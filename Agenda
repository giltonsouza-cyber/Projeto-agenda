// Lógica de geração do calendário de 2026
const getWeeksOf2026 = () => {
  const weeks = [];
  let currentDate = new Date(2026, 0, 1);
  const day = currentDate.getDay();
  // Ajusta para começar na segunda-feira
  const diff = currentDate.getDate() - day + (day === 0 ? -6 : 1);
  currentDate = new Date(currentDate.setDate(diff));
  for (let i = 1; i <= 53; i++) {
    const weekStart = new Date(currentDate);
    const weekEnd = new Date(currentDate);
    weekEnd.setDate(weekEnd.getDate() + 6);
    if (weekStart.getFullYear() > 2026 && i > 1) break;
    weeks.push({ number: i, start: weekStart, end: weekEnd, id: `week-2026-${i}` });
    currentDate.setDate(currentDate.getDate() + 7);
  }
  return weeks;
};

const formatDate = (date) => date.toLocaleDateString('pt-PT', { day: '2-digit', month: '2-digit' });

